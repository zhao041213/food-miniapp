<view class="container data-v-446f9d74"><view class="form data-v-446f9d74"><view class="form-item data-v-446f9d74"><text class="form-label data-v-446f9d74">菜品名称</text><input class="form-input data-v-446f9d74" placeholder="请输入菜品名称" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['form']]]]]}}" value="{{form.name}}" bindinput="__e"/></view><view class="form-item data-v-446f9d74"><text class="form-label data-v-446f9d74">价格</text><input class="form-input data-v-446f9d74" type="digit" placeholder="请输入价格" data-event-opts="{{[['input',[['__set_model',['$0','price','$event',['number']],['form']]]],['blur',[['$forceUpdate']]]]}}" value="{{form.price}}" bindinput="__e" bindblur="__e"/></view><view class="form-item data-v-446f9d74"><text class="form-label data-v-446f9d74">分类</text><picker value="{{categoryIndex}}" range="{{categories}}" data-event-opts="{{[['change',[['onCategoryChange',['$event']]]]]}}" bindchange="__e" class="data-v-446f9d74"><view class="picker data-v-446f9d74">{{''+(form.category||'请选择分类')+''}}</view></picker></view><view class="form-item data-v-446f9d74"><text class="form-label data-v-446f9d74">描述</text><textarea class="form-textarea data-v-446f9d74" placeholder="请输入菜品描述" data-event-opts="{{[['input',[['__set_model',['$0','description','$event',[]],['form']]]]]}}" value="{{form.description}}" bindinput="__e"></textarea></view><view class="form-item data-v-446f9d74"><text class="form-label data-v-446f9d74">图片</text><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="image-upload data-v-446f9d74" bindtap="__e"><block wx:if="{{form.image}}"><image class="preview-image data-v-446f9d74" src="{{form.image}}" mode="aspectFill"></image></block><block wx:else><view class="upload-placeholder data-v-446f9d74"><text class="upload-icon data-v-446f9d74">+</text><text class="upload-text data-v-446f9d74">点击上传图片</text></view></block></view></view><view class="form-btns data-v-446f9d74"><view data-event-opts="{{[['tap',[['cancel',['$event']]]]]}}" class="form-btn cancel data-v-446f9d74" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['save',['$event']]]]]}}" class="form-btn confirm data-v-446f9d74" bindtap="__e">保存</view></view></view></view>