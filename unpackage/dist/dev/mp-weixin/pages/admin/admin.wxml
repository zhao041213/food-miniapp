<view class="container data-v-14c8f526"><view class="header data-v-14c8f526"><view data-event-opts="{{[['tap',[['addDish',['$event']]]]]}}" class="add-btn data-v-14c8f526" bindtap="__e">+ 添加菜品</view></view><block wx:if="{{$root.g0===0}}"><view class="empty data-v-14c8f526"><text class="empty-icon data-v-14c8f526">🍽️</text><text class="empty-text data-v-14c8f526">暂无菜品</text></view></block><block wx:else><view class="dish-list data-v-14c8f526"><block wx:for="{{dishes}}" wx:for-item="dish" wx:for-index="__i0__" wx:key="id"><view class="dish-item data-v-14c8f526"><image class="dish-image data-v-14c8f526" src="{{dish.image}}" mode="aspectFill"></image><view class="dish-info data-v-14c8f526"><view class="dish-header data-v-14c8f526"><view class="dish-name data-v-14c8f526">{{dish.name}}</view><view class="{{['data-v-14c8f526','dish-status',dish.status===1?'active':'inactive']}}">{{''+(dish.status===1?'已上架':'已下架')+''}}</view></view><view class="dish-category data-v-14c8f526">{{dish.category}}</view><view class="dish-desc data-v-14c8f526">{{dish.description}}</view><view class="dish-price data-v-14c8f526">{{"¥"+dish.price}}</view></view><view class="dish-actions data-v-14c8f526"><view data-event-opts="{{[['tap',[['toggleStatus',['$0'],[[['dishes','id',dish.id]]]]]]]}}" class="{{['data-v-14c8f526','action-btn',dish.status===1?'offline':'online']}}" bindtap="__e">{{''+(dish.status===1?'下架':'上架')+''}}</view><view data-event-opts="{{[['tap',[['editDish',['$0'],[[['dishes','id',dish.id]]]]]]]}}" class="action-btn edit data-v-14c8f526" bindtap="__e">编辑</view><view data-event-opts="{{[['tap',[['deleteDish',['$0'],[[['dishes','id',dish.id]]]]]]]}}" class="action-btn delete data-v-14c8f526" bindtap="__e">删除</view></view></view></block></view></block></view>