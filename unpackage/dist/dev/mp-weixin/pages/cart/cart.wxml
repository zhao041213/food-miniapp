<view class="container data-v-0f00adf4"><block wx:if="{{$root.g0===0}}"><view class="empty data-v-0f00adf4"><text class="empty-icon data-v-0f00adf4">🛒</text><text class="empty-text data-v-0f00adf4">购物车是空的</text><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="empty-btn data-v-0f00adf4" bindtap="__e">去点餐</view></view></block><block wx:else><view class="data-v-0f00adf4"><view class="cart-list data-v-0f00adf4"><block wx:for="{{cart}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="cart-item data-v-0f00adf4"><image class="item-image data-v-0f00adf4" src="{{item.image}}" mode="aspectFill"></image><view class="item-info data-v-0f00adf4"><view class="item-name data-v-0f00adf4">{{item.name}}</view><view class="item-price data-v-0f00adf4">{{"¥"+item.price}}</view></view><view class="item-control data-v-0f00adf4"><view data-event-opts="{{[['tap',[['decreaseCount',['$0'],[[['cart','id',item.id]]]]]]]}}" class="control-btn data-v-0f00adf4" bindtap="__e">-</view><view class="control-count data-v-0f00adf4">{{item.count}}</view><view data-event-opts="{{[['tap',[['increaseCount',['$0'],[[['cart','id',item.id]]]]]]]}}" class="control-btn data-v-0f00adf4" bindtap="__e">+</view></view></view></block></view><view class="settle-bar data-v-0f00adf4"><view class="settle-info data-v-0f00adf4"><view class="settle-label data-v-0f00adf4">总计:</view><view class="settle-price data-v-0f00adf4">{{"¥"+totalPrice}}</view></view><view data-event-opts="{{[['tap',[['submitOrder',['$event']]]]]}}" class="settle-btn data-v-0f00adf4" bindtap="__e">提交订单</view></view></view></block></view>