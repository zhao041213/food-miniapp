
.container.data-v-57280228 {
	padding-bottom: 120rpx;
	background: #f5f5f5;
}

/* 搜索栏 */
.search-bar.data-v-57280228 {
	background: #fff;
	padding: 20rpx 30rpx;
	position: -webkit-sticky;
	position: sticky;
	top: 0;
	z-index: 100;
}
.search-input.data-v-57280228 {
	display: flex;
	align-items: center;
	background: #f5f5f5;
	border-radius: 30rpx;
	padding: 15rpx 25rpx;
}
.search-icon.data-v-57280228 {
	font-size: 32rpx;
	margin-right: 15rpx;
}
.search-input input.data-v-57280228 {
	flex: 1;
	font-size: 28rpx;
}
.search-placeholder.data-v-57280228 {
	color: #999;
}

/* 店铺信息 */
.shop-info.data-v-57280228 {
	display: flex;
	align-items: center;
	background: #fff;
	padding: 25rpx 30rpx;
	margin-bottom: 20rpx;
}
.shop-avatar.data-v-57280228 {
	width: 100rpx;
	height: 100rpx;
	border-radius: 12rpx;
	background: #FFE5E5;
	margin-right: 20rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 50rpx;
}
.shop-detail.data-v-57280228 {
	flex: 1;
}
.shop-name.data-v-57280228 {
	font-size: 32rpx;
	font-weight: bold;
	color: #333;
	margin-bottom: 10rpx;
}
.shop-tags.data-v-57280228 {
	display: flex;
	gap: 20rpx;
}
.shop-tag.data-v-57280228 {
	font-size: 24rpx;
	color: #999;
}

/* 横幅 */
.banner-section.data-v-57280228 {
	margin-bottom: 20rpx;
	padding: 0 30rpx;
}
.banner-swiper.data-v-57280228 {
	width: 100%;
	height: 280rpx;
}
.banner-image.data-v-57280228 {
	width: 100%;
	height: 100%;
	border-radius: 16rpx;
}

/* 分类导航 */
.category-nav.data-v-57280228 {
	background: #fff;
	padding: 20rpx 0;
	margin-bottom: 20rpx;
}
.category-scroll.data-v-57280228 {
	white-space: nowrap;
	padding: 0 20rpx;
}
.category-item.data-v-57280228 {
	display: inline-block;
	padding: 12rpx 30rpx;
	font-size: 28rpx;
	color: #666;
	border-radius: 30rpx;
	margin-right: 20rpx;
	transition: all 0.3s;
}
.category-item.active.data-v-57280228 {
	background: #FF6B6B;
	color: #fff;
	font-weight: bold;
}

/* 菜品列表 */
.dish-list.data-v-57280228 {
	padding: 0 20rpx;
}
.dish-item.data-v-57280228 {
	display: flex;
	background: #fff;
	border-radius: 16rpx;
	padding: 20rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.dish-image.data-v-57280228 {
	width: 200rpx;
	height: 200rpx;
	border-radius: 12rpx;
	background: #f0f0f0;
	flex-shrink: 0;
}
.dish-info.data-v-57280228 {
	flex: 1;
	margin-left: 20rpx;
	display: flex;
	flex-direction: column;
	justify-content: space-between;
}
.dish-name.data-v-57280228 {
	font-size: 32rpx;
	font-weight: bold;
	color: #333;
	margin-bottom: 8rpx;
}
.dish-desc.data-v-57280228 {
	font-size: 24rpx;
	color: #999;
	margin-bottom: 8rpx;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}
.dish-sales.data-v-57280228 {
	font-size: 22rpx;
	color: #999;
	margin-bottom: 8rpx;
}
.dish-bottom.data-v-57280228 {
	display: flex;
	justify-content: space-between;
	align-items: center;
}
.dish-price.data-v-57280228 {
