	align-items: baseline;
	color: #FF6B6B;
	font-weight: bold;
}
.price-symbol.data-v-57280228 {
	font-size: 24rpx;
}
.price-value.data-v-57280228 {
	font-size: 36rpx;
}
.add-btn.data-v-57280228 {
	width: 60rpx;
	height: 60rpx;
	background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
	border-radius: 50%;
